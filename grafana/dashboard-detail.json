        "calcsMutation": "standard",
        "centerAlignContent": true,
        "codeData": "{\n  \"text\": \"Random text\"\n}",
        "css": "* {\n  font-family: Open Sans;\n}\n\n.box {\n  border: solid #555 2px;\n  border-radius: 10px;\n  padding: 10px 20px;\n}\n",
        "dynamicData": false,
        "dynamicFieldDisplayValues": false,
        "dynamicHtmlGraphics": false,
        "dynamicProps": false,
        "html": "<div id=\"gallery-container\" \n     style=\"overflow-x:auto; white-space:nowrap; padding:10px; border:1px solid #333; border-radius:8px;\">\n  <div id=\"gallery\" \n       style=\"display:inline-flex; gap:12px; align-items:flex-start;\"></div>\n</div>\n",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "const container = htmlNode.querySelector(\"#gallery\");\n\n// Retry logic for data loading\nfunction renderGallery(retryCount = 0) {\n  const maxRetries = 5;\n  \n  try {\n    // Check if data is available\n    if (!data || !data.series || data.series.length === 0) {\n      if (retryCount < maxRetries) {\n        console.log(`Data not ready, retry ${retryCount + 1}/${maxRetries}`);\n        setTimeout(() => renderGallery(retryCount + 1), 500);\n        return;\n      }\n      container.innerHTML = '<p style=\"color:orange;\">Waiting for data... Please refresh if this persists.</p>';\n      return;\n    }\n\n    const series = data.series[0];\n    if (!series.fields || series.fields.length === 0) {\n      if (retryCount < maxRetries) {\n        setTimeout(() => renderGallery(retryCount + 1), 500);\n        return;\n      }\n      container.innerHTML = '<p style=\"color:red;\">No fields in data series.</p>';\n      return;\n    }\n\n    // Find fields\n    const screenshotField = series.fields.find(f => f.name === \"screenshot_url\" || f.name === \"screenshot\");\n    const activityField = series.fields.find(f => f.name === \"activity\");\n    const stepField = series.fields.find(f => f.name === \"step\");\n\n    if (!screenshotField) {\n      container.innerHTML = '<p style=\"color:red;\">No screenshot field found.</p>';\n      return;\n    }\n\n    const screenshots = screenshotField.values.toArray();\n    const activities = activityField?.values.toArray() || [];\n    const steps = stepField?.values.toArray() || [];\n\n    if (screenshots.length === 0) {\n      container.innerHTML = '<p style=\"color:orange;\">No screenshots available.</p>';\n      return;\n    }\n\n    // Clear container\n    container.innerHTML = \"\";\n\n    // Render screenshots\n    screenshots.forEach((url, i) => {\n      const div = document.createElement(\"div\");\n      div.style.textAlign = \"center\";\n\n      const img = document.createElement(\"img\");\n      img.src = url;\n      img.style.width = \"220px\";\n      img.style.border = \"1px solid #444\";\n      img.style.borderRadius = \"6px\";\n      img.style.marginBottom = \"6px\";\n      \n      // Add loading placeholder\n      img.style.background = \"#222\";\n      img.alt = \"Loading...\";\n      \n      // Error handling for images\n      img.onerror = function() {\n        this.style.border = \"2px solid red\";\n        this.alt = \"Failed to load\";\n      };\n\n      const label = document.createElement(\"div\");\n      label.textContent = `${activities[i] || \"Unknown\"} — Step ${steps[i] || i}`;\n      label.style.fontSize = \"12px\";\n      label.style.marginTop = \"4px\";\n\n      div.appendChild(img);\n      div.appendChild(label);\n      container.appendChild(div);\n    });\n\n    console.log(`✅ Rendered ${screenshots.length} screenshots`);\n  } catch (err) {\n    console.error(\"Error rendering screenshots:\", err);\n    container.innerHTML = `<p style=\"color:red;\">Error: ${err.message}</p>`;\n  }\n}\n\n// Start rendering\nrenderGallery();",
